# ============================================================
# Postiz self-host environment — TEMPLATE
# Copy to `.env` and fill in your own values. Do NOT commit `.env`.
# ============================================================

# --- Public URLs ---
# For local dev with ngrok static domain:
#   MAIN_URL=https://your-static.ngrok-free.app
# For a real domain in cloud:
#   MAIN_URL=https://postiz.yourdomain.com
MAIN_URL=https://your-static.ngrok-free.app
FRONTEND_URL=https://your-static.ngrok-free.app
NEXT_PUBLIC_BACKEND_URL=https://your-static.ngrok-free.app/api

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-string

# --- Internal services (container DNS, do not change) ---
DATABASE_URL=postgresql://postiz-user:postiz-password@postiz-postgres:5432/postiz-db-local
REDIS_URL=redis://postiz-redis:6379
BACKEND_INTERNAL_URL=http://localhost:3000
TEMPORAL_ADDRESS=temporal:7233

# --- App flags ---
IS_GENERAL=true
DISABLE_REGISTRATION=false
NX_ADD_PLUGINS=false
API_LIMIT=30

# --- Storage (local volume) ---
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# ============================================================
# Social providers — fill these in after creating developer apps.
# Each platform's OAuth redirect URI must be registered as:
#   ${MAIN_URL}/integrations/social/<provider>
# Specifically:
#   LinkedIn:  ${MAIN_URL}/integrations/social/linkedin
#   X:         ${MAIN_URL}/integrations/social/x
#   Facebook:  ${MAIN_URL}/integrations/social/facebook
#   TikTok:    ${MAIN_URL}/integrations/social/tiktok
# ============================================================

# --- X (Twitter) ---
X_API_KEY=
X_API_SECRET=

# --- LinkedIn ---
# Note: the patched linkedin.provider.js drops org scopes so only
# personal posting works. To enable Company Pages, restore upstream
# scopes and apply for LinkedIn's Community Management API.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Facebook + Instagram (one Meta app covers both) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- TikTok ---
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
